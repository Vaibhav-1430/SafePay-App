# Client runtime (pass via --dart-define)
SAFEPAY_API_BASE_URL=http://10.0.2.2:8081/api
SAFEPAY_MOBILE_API_KEY=replace-with-strong-random-key

# Server runtime (set in server/.env)
PORT=8080
NODE_ENV=development
JWT_SECRET=replace-me
JWT_EXPIRES_IN=12h
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# AI backend runtime (set in ai-backend/.env)
PORT=8081
NODE_ENV=development
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
MOBILE_API_KEY=replace-with-strong-random-key
